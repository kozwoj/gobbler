// ------------------- somescalars -------------------
###
POST http://localhost:3000/v1/definition/new
Authorization: Bearer abc123==
Content-Type: application/json

[
    {
        "Name": "somescalars",
        "Documentation": "table One",
        "Folder": "my folder",
        "OrderedColumns": [
            { "Name": "_string", "Type": "string", "DefaultValue": "value" },
            { "Name": "_boolean", "Type": "bool", "DefaultValue": true, "Optional": true },
            { "Name": "_datetime", "Type": "datetime", "DefaultValue": true, "Optional": false },
            { "Name": "_int", "Type": "int", "Optional": false },
            { "Name": "_real", "Type": "real", "DefaultValue": 55.55 }
        ],
        "IngestionLatencyInMinutes": 10,
        "RetentionInDays": 30
    }
]

###
POST http://localhost:3000/v1/ingest
Authorization: Bearer abc123==
Content-Type: application/json

[
    { "somescalars": { "_string": "Hyundai", "_boolean": true, "_datetime": "2018-05-01T01:40:42.902Z", "_int": 0, "_real": 12537.5948 } }
]

###
POST http://localhost:3000/v1/ingest
Authorization: Bearer abc123==
Content-Type: application/json

[
    { "somescalars": { "_string": "Hyundaiii", "_boolean": true, "_datetime": "2018-05-01T01:40:42.902Z", "_int": 0, "_real": 12537.5948 } },
    { "somescalars": { "_string": "Plymouth", "_boolean": true, "_datetime": "2018-05-01T01:40:43.414Z", "_int": 1, "_real": 35280.1204 } },
    { "somescalars": { "_string": "Mercury", "_boolean": true, "_datetime": "2018-05-01T01:40:43.919Z", "_int": 4, "_real": 47188.7112 } },
    { "somescalars": { "_string": "Subaru", "_boolean": false, "_datetime": "2018-05-01T01:40:44.424Z", "_int": 4, "_real": 29606.8954 } }
]
