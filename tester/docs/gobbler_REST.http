// **************************** type definitions ****************************

###
GET http://localhost:3000/gobbler/definition/list
Authorization: Bearer abc123==

//------------------- vmReboot -------------------
###
POST http://localhost:3000/gobbler/definition/add
Authorization: Bearer abc123==
Content-Type: application/json

{
	"name": "vmReboot",
	"documentation": "virtual machine reboot event",
	"folder": "administration",
	"latencyMinutes": 10,
	"orderedColumns": [
		{"name": "vmId", "type": "string"},
		{"name": "eventTime", "type": "datetime"},
		{"name": "rebootStart", "type": "datetime"},
		{"name": "rebootDuration", "type": "timespan", "optional": true},
        {"name": "rebootReason", "type": "string", "defaultValue": "unknown", "optional": false},
		{"name": "OS", "type": "dynamic", "defaultValue": "{\"os\": \"Windows\", \"version\": \"11\"}", "optional": false}
	]
}

###
GET http://localhost:3000/gobbler/definition/list
Authorization: Bearer abc123==

###
POST http://localhost:3000/gobbler/definition/remove
Authorization: Bearer abc123==
Content-Type: application/json

{ "typeName": "vmReboot" }


//------------------- vmShutdown ------------------- 
###
POST http://localhost:3000/gobbler/definition/add
Authorization: Bearer abc123==
Content-Type: application/json

{
	"name": "vmShutdown",
	"documentation": "virtual machine shutdown event",
	"folder": "administration",
	"latencyMinutes": 10,
	"orderedColumns": [
		{"name": "vmId", "type": "string"},
		{"name": "shutdownStart", "type": "datetime"},
		{"name": "shutdownReason", "type": "string", "defaultValue": "unknown", "optional": false}
	]
}

###
GET http://localhost:3000/gobbler/definition/list
Authorization: Bearer abc123==

###
POST http://localhost:3000/gobbler/definition/remove
Authorization: Bearer abc123==
Content-Type: application/json

{ "typeName": "vmShutdown" }


// ------------------- allscalars -------------------
###
POST http://localhost:3000/gobbler/definition/add
Authorization: Bearer abc123==
Content-Type: application/json

{
	"name": "allscalars",
	"documentation": "table with all scalar types",
	"folder": "folderOne",
	"latencyMinutes": 10,
	"orderedColumns": [
		{"name": "_string", "type": "string", "defaultValue": "value", "optional": true},
        {"name": "_boolean", "type": "bool", "defaultValue": true, "optional": false},
        {"name": "_datetime", "type": "datetime", "defaultValue": "2000-01-01 00:00:01.100", "optional": false},
        {"name": "_dynamic", "type": "dynamic", "defaultValue": "{\"key\": \"value\"}", "optional": false},
        {"name": "_int", "type": "int", "defaultValue": 10, "optional": false},
        {"name": "_real", "type": "real", "defaultValue": 55.55},
        {"name": "_timespan", "type": "timespan", "optional": true}
	]
}


###
GET http://localhost:3000/gobbler/definition/list
Authorization: Bearer abc123==

###
POST http://localhost:3000/gobbler/definition/remove
Authorization: Bearer abc123==
Content-Type: application/json

{ "typeName": "allscalars" }


// **************************** ingestion ****************************

###
POST http://localhost:3000/gobbler/ingest
Authorization: Bearer abc123==
Content-Type: application/json

[
    {"one":"one"},
    {"two":"two"}
]


###
POST http://localhost:3000/gobbler/ingest
Authorization: Bearer abc123==
Content-Type: application/json

[
    { "vmShutdown": { "vmId": "vm_87345882", "shutdownStart": "2018-05-01 01:40:42.902", "shutdownReason": "OS update" } },
    { "vmShutdown": { "vmId": "vm_76445833", "shutdownStart": "2018-05-01 01:40:44.424", "shutdownReason": "Live migration" }}
]

