    {"allscalars": {"_string":"Hyundai","_boolean":true,"_datetime":"2018-05-01 01:40:42.902","_dynamic":"{\"color\":\"Crimson\",\"size\":\"small\"}","_int":0,"_real":12537.5948,"_timespan":"7d"}}
]

###
POST http://localhost:3000/gobbler/ingest
Authorization: Bearer abc123==
Content-Type: application/json

[
    {"allscalars":{"_string":"Hyundaiii","_boolean":true,"_datetime":"2018-05-01 01:40:42.902","_dynamic":"{\"color\":\"Crimson\",\"size\":\"small\"}","_int":0,"_real":12537.5948,"_timespan":"7d"}},
    {"allscalars":{"_string":"Plymouth","_boolean":true,"_datetime":"2018-05-01 01:40:43.414","_dynamic":"{\"color\":\"Purple\",\"size\":\"mediem\"}","_int":1,"_real":35280.1204,"_timespan":"8s"}},
    {"allscalars":{"_string":"Mercury","_boolean":true,"_datetime":"2018-05-01 01:40:43.919","_dynamic":"{\"color\":\"Pink\",\"size\":\"ex-large\"}","_int":4,"_real":47188.7112,"_timespan":"9s"}},
