// ------------------- somescalars -------------------
###
POST http://localhost:3000/gobbler/definition/add
Authorization: Bearer abc123==
Content-Type: application/json

{
    "name": "somescalars",
    "documentation": "table One",
    "folder": "myFolder",
    "latencyMinutes": 10,
    "orderedColumns": [
        { "name": "_string", "type": "string", "defaultValue": "value" },
        { "name": "_boolean", "type": "bool", "defaultValue": true, "optional": true },
        { "name": "_datetime", "type": "datetime", "optional": false },
        { "name": "_int", "type": "int", "optional": false },
        { "name": "_real", "type": "real", "defaultValue": 55.55 }
    ]
}

###
POST http://localhost:3000/gobbler/ingest
Authorization: Bearer abc123==
Content-Type: application/json

[
    { "somescalars": { "_string": "Hyundai", "_boolean": true, "_datetime": "2018-05-01 01:40:42.902", "_int": 0, "_real": 12537.5948 } }
]

###
POST http://localhost:3000/gobbler/ingest
Authorization: Bearer abc123==
Content-Type: application/json

[
    { "somescalars": { "_string": "Hyundaiii", "_boolean": true, "_datetime": "2018-05-01 01:40:42.902", "_int": 0, "_real": 12537.5948 } },
    { "somescalars": { "_string": "Plymouth", "_boolean": true, "_datetime": "2018-05-01 01:40:43.414", "_int": 1, "_real": 35280.1204 } },
    { "somescalars": { "_string": "Mercury", "_boolean": true, "_datetime": "2018-05-01 01:40:43.919", "_int": 4, "_real": 47188.7112 } },
    { "somescalars": { "_string": "Subaru", "_boolean": false, "_datetime": "2018-05-01 01:40:44.424", "_int": 4, "_real": 29606.8954 } }
]
